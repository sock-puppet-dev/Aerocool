
{

  "compilerOptions": {

    "target": "ES2022",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "lib": ["ES2022"],

    "types": ["node"],

    "strict": true,

    "skipLibCheck": true,

    "esModuleInterop": true,

    "allowSyntheticDefaultImports": true,

    "resolveJsonModule": true,

    "noEmit": true

  },

  "include": [

    "*.config.ts"

  ],

  "exclude": [

    "node_modules",

    "reports"

  ]

}

