{{ $schemaTypes := .Params.schema_types | default (slice) }}
{{ if and .IsPage (in $schemaTypes "article") }}
{{ $pageImage := partial "page-image.gohtml" . }}
{{ $pageLanguage := partial "page-language.gohtml" . }}
{{ $websiteId := partial "page-website-id.gohtml" . }}

{
  "@type": "Article",
  "@id": "{{ .Permalink | absURL }}#article",

  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ .Permalink | absURL }}"
  },

  "headline": {{ .Title | jsonify }},
  "description": {{ .Params.description | default .Summary | plainify | jsonify }},

  "image": [
    "{{ $pageImage }}"
  ],

  "datePublished": "{{ .Date.Format "2006-01-02T15:04:05Z07:00" }}",
  "dateModified": "{{ .Lastmod.Format "2006-01-02T15:04:05Z07:00" }}",

  "author": {
    "@type": "Organization",
    "@id": "{{ .Site.BaseURL | absURL }}#organization"
  },

  "publisher": {
    "@type": "Organization",
    "@id": "{{ .Site.BaseURL | absURL }}#organization",
    "logo": {
      "@id": "{{ .Site.BaseURL | absURL }}#logo"
    }
  },

  "isPartOf": {
    "@id": "{{ $websiteId }}"
  },

  "articleSection": "{{ .Section }}",
  "wordCount": {{ .WordCount }},

  "inLanguage": "{{ $pageLanguage }}"
}
{{ end }}
