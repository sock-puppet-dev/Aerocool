{{- $pageNumber := .Scratch.Get "pageNumber" | default 1 -}}
{{- $pageSuffix := "" -}}
{{- if gt $pageNumber 1 -}}
  {{- if eq .Site.Language.Lang "ru" -}}
    {{- $pageSuffix = printf " | Страница %d" $pageNumber -}}
  {{- else -}}
    {{- $pageSuffix = printf " | Сторінка %d" $pageNumber -}}
  {{- end -}}
{{- end -}}
{{- printf "%s%s" (cond .IsHome .Site.Title (printf "%s | %s" .Title .Site.Title)) $pageSuffix -}}
