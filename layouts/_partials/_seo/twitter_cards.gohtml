{{ $title := partial "page-title.gohtml" . }}
{{ $description := partial "page-description.gohtml" . }}
{{ $url := .Scratch.Get "pagePermalink" | default (.Permalink | absURL) }}
{{ $image := partial "page-image.gohtml" . }}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content="{{ $title }}" />
<meta name="twitter:description" content="{{ $description }}" />
<meta name="twitter:image" content="{{ $image }}" />
<meta name="twitter:url" content="{{ $url }}" />
<meta name="twitter:site" content="@AerocoolGlobal" />
