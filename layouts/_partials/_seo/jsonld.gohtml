{{- $graph := slice -}}

{{/* ======================== ГЛОБАЛЬНЫЕ СУЩНОСТИ ======================== */}}
{{- $graph = $graph | append (partial "_schema/website.gohtml" .) -}}
{{- $graph = $graph | append (partial "_schema/local-organization.gohtml" .) -}}
{{- $graph = $graph | append (partial "_schema/global-organization.gohtml" .) -}}
{{- $graph = $graph | append (partial "_schema/brand.gohtml" .) -}}

{{/* ======================== TYPES ======================== */}}
{{- $schemaTypes := .Params.schema_types | default (slice) -}}
{{- $hasBreadcrumbs := or (in $schemaTypes "breadcrumbs") (.Params.breadcrumbs) .IsHome (eq .Kind "section") (eq .Kind "taxonomy") (eq .Kind "term") -}}

{{/* ======================== КОНТЕНТНЫЕ СУЩНОСТИ ======================== */}}

{{/* NEWS */}}
{{- if and .IsPage (in $schemaTypes "news") -}}
  {{- $graph = $graph | append (partial "_schema/news.gohtml" .) -}}
{{- end -}}

{{/* ARTICLE */}}
{{- if and .IsPage (in $schemaTypes "article") -}}
  {{- $graph = $graph | append (partial "_schema/article.gohtml" .) -}}
{{- end -}}

{{/* PRODUCT */}}
{{- if and .IsPage (in $schemaTypes "product") -}}
  {{- $graph = $graph | append (partial "_schema/product.gohtml" .) -}}
{{- end -}}

{{/* ======================== СПЕЦИАЛЬНЫЕ СУЩНОСТИ ======================== */}}

{{/* FAQ */}}
{{- if or (in $schemaTypes "faq") (.Params.faq) -}}
  {{- $graph = $graph | append (partial "_schema/faq.gohtml" .) -}}
{{- end -}}

{{/* BREADCRUMBS */}}
{{- if $hasBreadcrumbs -}}
  {{- $graph = $graph | append (partial "_schema/breadcrumbs.gohtml" .) -}}
{{- end -}}

{{/* COLLECTION (категории / списки) */}}
{{- if or (in $schemaTypes "collection") (eq .Kind "section") (eq .Kind "taxonomy") (eq .Kind "term") -}}
  {{- $graph = $graph | append (partial "_schema/collection.gohtml" .) -}}
{{- end -}}

{{/* WEBPAGE */}}
{{- $graph = $graph | append (partial "_schema/webpage.gohtml" .) -}}

{{/* ======================== ФИНАЛЬНЫЙ ВЫВОД ======================== */}}

{{- $graphJSON := delimit $graph "," -}}
{{- $jsonld := printf `{
  "@context": "https://schema.org",
  "@graph": [%s]
}` $graphJSON -}}

{{- printf `<script type="application/ld+json">%s</script>` $jsonld | safeHTML -}}
