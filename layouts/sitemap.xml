{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xhtml="http://www.w3.org/1999/xhtml">
  {{- range site.Pages }}
    {{- if not (or .Draft (eq .Layout "search") (eq .Params.robotsNoIndex true) (eq .Kind "taxonomy") (eq .Kind "term")) }}
    <url>
      <loc>{{ .Permalink }}</loc>
      {{- if not .Lastmod.IsZero }}
      {{- $lastmod := .Lastmod -}}
      {{- $hasClockTime := not (and (eq $lastmod.Hour 0) (eq $lastmod.Minute 0) (eq $lastmod.Second 0)) -}}
      <lastmod>{{ if $hasClockTime }}{{ $lastmod.Format "2006-01-02T15:04:05-07:00" }}{{ else }}{{ $lastmod.Format "2006-01-02" }}{{ end }}</lastmod>
      {{- end }}
      {{- if .IsTranslated }}
        {{- range .AllTranslations }}
        <xhtml:link rel="alternate" hreflang="{{ partial "page-language.html" . }}" href="{{ .Permalink }}" />
        {{- end }}
      {{- end }}
    </url>
    {{- end }}
  {{- end }}
</urlset>
